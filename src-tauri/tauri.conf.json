{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parch ISO Writer",
  "version": "0.1.2",
  "identifier": "com.parchlinux.iso-writer",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Parch ISO Writer",
        "width": 860,
        "height": 680,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {},
    "windows": {},
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
